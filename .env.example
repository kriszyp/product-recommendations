# ── Origin product API ─────────────────────────────────────────────────────────
# Base URL for the external product catalogue (Salesforce Commerce Cloud compatible).
# Expected endpoint: GET {ORIGIN_PRODUCT_API_URL}/products/{productId}
# If unset, only products explicitly passed in the request body will be cached.
ORIGIN_PRODUCT_API_URL=https://your-sfcc-instance.api.commercecloud.salesforce.com/s/SiteId/dw/shop/v22_4

# Bearer token / API key for the origin API (omit if not required)
ORIGIN_PRODUCT_API_KEY=

# ── Caching ────────────────────────────────────────────────────────────────────
# How long product details are cached before re-fetching from origin (seconds, default 24 h)
PRODUCT_CACHE_TTL_SECONDS=86400

# ── Session tracking ──────────────────────────────────────────────────────────
# Maximum number of product IDs kept in a user's session history
MAX_SESSION_HISTORY=20
# How many of the most-recent session products to create associations with
ASSOC_WINDOW=10

# ── Association scoring ───────────────────────────────────────────────────────
# Score multiplier applied to PMI-normalized association weight (default 10)
ASSOC_WEIGHT=10
# Exponential decay half-life for association scores in milliseconds (default 30 days)
DECAY_HALF_LIFE_MS=2592000000

# ── Second-order graph traversal ─────────────────────────────────────────────
# Expand neighbours-of-neighbours when fewer than this many direct candidates exist
SECOND_ORDER_THRESHOLD=10
# Score discount applied to second-hop candidates (0–1, default 0.3)
SECOND_ORDER_DISCOUNT=0.3
# How many top first-hop neighbours to expand (default 5)
SECOND_ORDER_HOPS=5

# ── Recommendation engine ─────────────────────────────────────────────────────
# Maximum recommendations returned per request
MAX_RECOMMENDATIONS=10
# Jaccard similarity threshold for text-based bootstrapping (0–1)
TEXT_SIM_THRESHOLD=0.05
# Number of strong learned associations required before text similarity is skipped
ASSOC_BOOTSTRAP_THRESHOLD=3

# ── Diversity re-ranking ─────────────────────────────────────────────────────
# Over-fetch multiplier before diversity re-rank (default 3×)
DIVERSITY_OVERSAMPLE=3
# Score multiplier penalty per repeated category (0=strict alternation, 1=disabled, default 0.5)
CATEGORY_PENALTY=0.5
# Hard cap: max recommendations from the same category (default 3)
MAX_PER_CATEGORY=3

# ── Exploration / anti-feedback-loop (Phase 6 — optional) ────────────────────
# UCB-style bonus: products recommended rarely get a boost so new products can
# earn associations and the graph avoids self-reinforcing popular-only loops.
# EXPLORE_WEIGHT=0 (default) disables entirely — zero overhead, no behaviour change.
# A value equal to SEMANTIC_WEIGHT (5) is a good starting point.
EXPLORE_WEIGHT=0
# How many products with no prior association/similarity signal to inject per request
# as pure exploration candidates. Set to 0 to only boost already-scored products.
EXPLORE_FORCE_CANDIDATES=10

# ── Semantic embeddings (Phase 5 — optional) ─────────────────────────────────
# Embedding provider: "openai", "ollama", or "" (disabled — falls back to Jaccard)
EMBEDDING_PROVIDER=
# OpenAI settings (used when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Ollama settings (used when EMBEDDING_PROVIDER=ollama)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Minimum cosine similarity to include a vector candidate (0–1, default 0.6)
VECTOR_SIM_THRESHOLD=0.6
# Number of vector candidates to retrieve from HNSW index (default 50)
SEMANTIC_CANDIDATES=50
# Score multiplier for semantic similarity signal (default 5)
SEMANTIC_WEIGHT=5

# ── Harper Fabric deployment ──────────────────────────────────────────────────
CLI_TARGET='YOUR_FABRIC.HARPER.FAST_CLUSTER_URL_HERE'
CLI_TARGET_USERNAME='YOUR_CLUSTER_USERNAME'
CLI_TARGET_PASSWORD='YOUR_CLUSTER_PASSWORD'
