# ── Origin product API ─────────────────────────────────────────────────────────
# Base URL for the external product catalogue (Salesforce Commerce Cloud compatible).
# Expected endpoint: GET {ORIGIN_PRODUCT_API_URL}/products/{productId}
# If unset, only products explicitly passed in the request body will be cached.
ORIGIN_PRODUCT_API_URL=https://your-sfcc-instance.api.commercecloud.salesforce.com/s/SiteId/dw/shop/v22_4

# Bearer token / API key for the origin API (omit if not required)
ORIGIN_PRODUCT_API_KEY=

# ── Caching ────────────────────────────────────────────────────────────────────
# How long product details are cached before re-fetching from origin (seconds, default 24 h)
PRODUCT_CACHE_TTL_SECONDS=86400

# ── Session tracking ──────────────────────────────────────────────────────────
# Maximum number of product IDs kept in a user's session history
MAX_SESSION_HISTORY=20
# How many of the most-recent session products to create associations with
ASSOC_WINDOW=10

# ── Recommendation engine ─────────────────────────────────────────────────────
# Maximum recommendations returned per request
MAX_RECOMMENDATIONS=10
# Jaccard similarity threshold for text-based bootstrapping (0–1)
TEXT_SIM_THRESHOLD=0.05
# Number of strong learned associations required before text similarity is skipped
ASSOC_BOOTSTRAP_THRESHOLD=3

# ── Harper Fabric deployment ──────────────────────────────────────────────────
CLI_TARGET='YOUR_FABRIC.HARPER.FAST_CLUSTER_URL_HERE'
CLI_TARGET_USERNAME='YOUR_CLUSTER_USERNAME'
CLI_TARGET_PASSWORD='YOUR_CLUSTER_PASSWORD'
